        <div class="service-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="6" height="20" rx="2"/><path d="M9 6h12M9 12h8M9 18h10"/></svg></div>
