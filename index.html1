<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5.0"/>
<title>ACare Service — Aircon Cleaning & Maintenance, Metro Manila</title>
<meta name="description" content="Professional aircon cleaning and maintenance across Metro Manila. Book via Messenger, WhatsApp, or Viber."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;font-size:16px;}
body{font-family:'Inter',sans-serif;background:#0a1628;color:#e2eaf4;overflow-x:hidden;line-height:1.6;}
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:#0d1f3c;}
::-webkit-scrollbar-thumb{background:#2a7fba;border-radius:3px;}
:root{
  --midnight:#0a1628;
  --navy:#0d1f3c;
  --navy-mid:#112444;
  --navy-light:#162d52;
  --coastal:#1a5f8a;
  --ocean:#2a7fba;
  --wave:#3a9fd4;
  --foam:#7ecef4;
  --mist:#b8dff0;
  --white:#e2eaf4;
  --gray:#7a9bb5;
  --border:rgba(58,159,212,0.15);
  --card:rgba(17,36,68,0.8);
  --glow:0 0 40px rgba(42,127,186,0.15);
  --shadow:0 4px 32px rgba(0,0,0,0.3);
  --shadow-hover:0 12px 48px rgba(42,127,186,0.25);
  --wa:#25D366;
  --viber:#7360f2;
  --messenger:#0084ff;
  --font-display:'Plus Jakarta Sans',sans-serif;
}
/* REVEAL ANIMATIONS */
.reveal{opacity:0;transform:translateY(44px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);}
.reveal.in{opacity:1;transform:translateY(0);}
.reveal-scale{opacity:0;transform:scale(.88);transition:opacity .6s cubic-bezier(.22,1,.36,1),transform .6s cubic-bezier(.22,1,.36,1);}
.reveal-scale.in{opacity:1;transform:scale(1);}
.reveal-left{opacity:0;transform:translateX(-44px);transition:opacity .65s cubic-bezier(.22,1,.36,1),transform .65s cubic-bezier(.22,1,.36,1);}
.reveal-left.in{opacity:1;transform:translateX(0);}
.reveal-right{opacity:0;transform:translateX(44px);transition:opacity .65s cubic-bezier(.22,1,.36,1),transform .65s cubic-bezier(.22,1,.36,1);}
.reveal-right.in{opacity:1;transform:translateX(0);}
.d1{transition-delay:.08s!important;} .d2{transition-delay:.16s!important;} .d3{transition-delay:.24s!important;}
.d4{transition-delay:.32s!important;} .d5{transition-delay:.40s!important;} .d6{transition-delay:.48s!important;}
@media(prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important;}}

/* NAVBAR */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:68px;padding:0 clamp(20px,5vw,80px);display:flex;align-items:center;justify-content:space-between;transition:all .35s ease;background:transparent;}
nav.scrolled{background:rgba(10,22,40,0.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);box-shadow:0 4px 32px rgba(0,0,0,0.4);}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-mark{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--coastal),var(--wave));display:flex;align-items:center;justify-content:center;color:#fff;transition:transform .3s;}
.logo:hover .logo-mark{transform:rotate(18deg) scale(1.1);}
.logo-text{font-family:var(--font-display);font-weight:800;font-size:1.2rem;color:var(--white);}
.logo-text span{color:var(--wave);}
.nav-links{display:flex;align-items:center;gap:2rem;}
.nav-links a{color:var(--gray);text-decoration:none;font-weight:500;font-size:.9rem;transition:color .2s;}
.nav-links a:hover{color:var(--foam);}
.nav-cta{background:linear-gradient(135deg,var(--coastal),var(--wave));color:#fff!important;padding:9px 22px;border-radius:10px;font-weight:600!important;font-size:.875rem!important;box-shadow:0 4px 16px rgba(42,127,186,.35);transition:transform .2s,box-shadow .2s!important;}
.nav-cta:hover{transform:translateY(-2px) scale(1.03);box-shadow:0 8px 28px rgba(42,127,186,.5);}
.hamburger{display:none;background:none;border:none;cursor:pointer;color:var(--white);padding:4px;}
.mobile-menu{position:fixed;top:68px;left:0;right:0;background:rgba(10,22,40,0.98);backdrop-filter:blur(20px);padding:24px 5%;display:flex;flex-direction:column;gap:18px;border-bottom:1px solid var(--border);transform:translateY(-12px);opacity:0;pointer-events:none;transition:all .25s ease;z-index:999;}
.mobile-menu.open{transform:translateY(0);opacity:1;pointer-events:auto;}
.mobile-menu a{color:var(--white);text-decoration:none;font-weight:600;font-size:1rem;padding:8px 0;border-bottom:1px solid var(--border);}
@media(max-width:860px){.nav-links{display:none;}.hamburger{display:block;}}

/* HERO */
#hero{min-height:100vh;background:linear-gradient(160deg,#0a1628 0%,#0d1f3c 50%,#0f2545 100%);display:flex;align-items:center;padding:100px clamp(20px,5vw,80px) 60px;position:relative;overflow:hidden;}
.hero-bg-glow{position:absolute;border-radius:50%;pointer-events:none;filter:blur(80px);}
.glow1{width:600px;height:600px;top:-20%;right:-10%;background:radial-gradient(circle,rgba(42,127,186,.18) 0%,transparent 70%);animation:glowpulse 8s ease-in-out infinite;}
.glow2{width:400px;height:400px;bottom:-15%;left:-5%;background:radial-gradient(circle,rgba(26,95,138,.15) 0%,transparent 70%);animation:glowpulse 11s ease-in-out infinite 2s;}
.glow3{width:300px;height:300px;top:40%;left:35%;background:radial-gradient(circle,rgba(58,159,212,.08) 0%,transparent 70%);animation:glowpulse 9s ease-in-out infinite 1s;}
@keyframes glowpulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.12);opacity:.6;}}
/* grid lines */
#hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(42,127,186,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(42,127,186,.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;}
#particles{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
.particle{position:absolute;border-radius:50%;animation:floaty 5s ease-in-out infinite;}
@keyframes floaty{0%,100%{transform:translate(0,0);opacity:.25;}50%{transform:translate(8px,-28px);opacity:.7;}}

.hero-inner{position:relative;z-index:1;max-width:1100px;width:100%;margin:0 auto;}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;}
@media(max-width:860px){.hero-grid{grid-template-columns:1fr;}.hero-images{display:none;}}

.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(42,127,186,.12);border:1px solid rgba(58,159,212,.25);border-radius:50px;padding:6px 16px;font-size:.78rem;font-weight:700;color:var(--wave);letter-spacing:.08em;text-transform:uppercase;margin-bottom:24px;}
.badge-dot{width:7px;height:7px;border-radius:50%;background:var(--wave);display:inline-block;animation:blink 1.5s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.3;transform:scale(1.4);}}
h1{font-family:var(--font-display);font-size:clamp(2.4rem,5vw,4rem);font-weight:800;line-height:1.05;letter-spacing:-.03em;color:var(--white);margin-bottom:20px;}
.gradient-text{background:linear-gradient(135deg,var(--wave),var(--foam));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
.hero-sub{font-size:1.05rem;color:var(--gray);max-width:440px;line-height:1.75;margin-bottom:36px;}
.hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:48px;}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--coastal),var(--wave));color:#fff;text-decoration:none;font-weight:700;font-size:1rem;padding:14px 28px;border-radius:12px;box-shadow:0 4px 24px rgba(42,127,186,.4);transition:transform .2s,box-shadow .2s;}
.btn-primary:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 10px 32px rgba(42,127,186,.55);}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.05);color:var(--white);text-decoration:none;font-weight:600;font-size:1rem;padding:14px 28px;border-radius:12px;border:1.5px solid var(--border);transition:all .2s;}
.btn-secondary:hover{background:rgba(42,127,186,.12);border-color:rgba(58,159,212,.4);transform:translateY(-2px);}
.hero-stats{display:flex;flex-wrap:wrap;gap:32px;}
.stat-num{font-family:var(--font-display);font-weight:800;font-size:1.8rem;color:var(--white);line-height:1;}
.stat-label{font-size:.78rem;color:var(--gray);margin-top:4px;text-transform:uppercase;letter-spacing:.06em;}

/* Hero image cards */
.hero-images{position:relative;height:480px;}
.hi-card{position:absolute;border-radius:20px;overflow:hidden;border:2px solid rgba(58,159,212,.2);box-shadow:0 20px 60px rgba(0,0,0,.4);animation:floatcard 5s ease-in-out infinite;}
.hi-back{top:30px;right:0;width:78%;height:310px;animation-delay:.5s;}
.hi-front{bottom:0;left:0;width:68%;height:270px;}
@keyframes floatcard{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
.hi-img{width:100%;height:100%;object-fit:cover;}
.hi-label{position:absolute;bottom:14px;left:14px;background:rgba(10,22,40,.88);backdrop-filter:blur(8px);border-radius:10px;padding:8px 14px;border:1px solid var(--border);}
.hi-label strong{display:block;font-weight:700;font-size:.82rem;color:var(--foam);}
.hi-label span{font-size:.72rem;color:var(--gray);}
.hi-badge{position:absolute;top:10px;left:14%;background:rgba(13,31,60,.95);border:1px solid rgba(58,159,212,.25);border-radius:14px;padding:12px 16px;box-shadow:0 8px 32px rgba(0,0,0,.3);display:flex;align-items:center;gap:10px;animation:floatbadge 4s ease-in-out infinite 1s;}
@keyframes floatbadge{0%,100%{transform:translateY(0) rotate(0);}50%{transform:translateY(-7px) rotate(2deg);}}
.hi-badge-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,rgba(42,127,186,.2),rgba(58,159,212,.2));display:flex;align-items:center;justify-content:center;color:var(--wave);}
.hi-badge strong{display:block;font-weight:700;font-size:.8rem;color:var(--white);}
.hi-badge span{font-size:.7rem;color:var(--gray);}

/* SECTIONS */
section{position:relative;z-index:1;}
.sec-inner{max-width:1100px;margin:0 auto;padding:96px clamp(20px,5vw,80px);}
.sec-label{font-size:.78rem;font-weight:700;color:var(--wave);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;}
h2{font-family:var(--font-display);font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);letter-spacing:-.02em;color:var(--white);line-height:1.15;margin-bottom:14px;}
.sec-desc{color:var(--gray);font-size:1.05rem;max-width:460px;line-height:1.7;margin-bottom:52px;}

/* SERVICES */
#services{background:var(--navy);}
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;}
.service-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px 24px;transition:transform .25s,box-shadow .25s,border-color .25s;cursor:default;backdrop-filter:blur(8px);}
.service-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-hover);border-color:rgba(58,159,212,.35);}
.service-icon{width:50px;height:50px;border-radius:14px;background:linear-gradient(135deg,rgba(42,127,186,.18),rgba(58,159,212,.12));display:flex;align-items:center;justify-content:center;color:var(--wave);margin-bottom:18px;transition:transform .3s;}
.service-card:hover .service-icon{transform:rotate(10deg) scale(1.1);}
.service-card h3{font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--white);margin-bottom:8px;}
.service-card p{font-size:.875rem;color:var(--gray);line-height:1.65;}

/* GALLERY */
#gallery{background:var(--midnight);}
.gallery-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;}
.gallery-item{border-radius:20px;overflow:hidden;position:relative;cursor:pointer;box-shadow:var(--shadow);height:240px;border:1px solid var(--border);transition:transform .3s,box-shadow .3s;}
.gallery-item:hover{transform:scale(1.03) translateY(-4px);box-shadow:var(--shadow-hover);}
.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .5s;filter:brightness(.88);}
.gallery-item:hover img{transform:scale(1.08);filter:brightness(1);}
.gallery-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,22,40,.92) 0%,rgba(10,22,40,.1) 55%);}
.gallery-text{position:absolute;bottom:16px;left:18px;}
.gallery-text strong{display:block;color:#fff;font-weight:700;font-size:.95rem;margin-bottom:2px;}
.gallery-text span{font-size:.75rem;color:var(--foam);}

/* LIGHTBOX */
#lightbox{position:fixed;inset:0;z-index:3000;background:rgba(5,12,25,.95);backdrop-filter:blur(12px);display:none;align-items:center;justify-content:center;padding:20px;opacity:0;transition:opacity .3s;}
#lightbox.open{display:flex;opacity:1;}
.lightbox-card{border-radius:20px;overflow:hidden;max-width:780px;width:100%;box-shadow:0 40px 80px rgba(0,0,0,.6);border:1px solid var(--border);transform:scale(.88);transition:transform .3s;}
#lightbox.open .lightbox-card{transform:scale(1);}
.lightbox-info{background:var(--navy-mid);padding:16px 20px;border-top:1px solid var(--border);}
.lightbox-info strong{display:block;color:var(--white);font-weight:700;}
.lightbox-info span{font-size:.85rem;color:var(--gray);}

/* PRICING */
#pricing{background:var(--navy);}
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;}
.price-card{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:32px 28px;display:flex;flex-direction:column;position:relative;overflow:hidden;backdrop-filter:blur(8px);transition:transform .25s,box-shadow .25s;}
.price-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-hover);}
.price-card.featured{border-color:rgba(58,159,212,.4);background:linear-gradient(160deg,rgba(42,127,186,.1),rgba(10,22,40,.9));}
.price-card.featured::before{content:'Most Popular';position:absolute;top:18px;right:-30px;background:linear-gradient(135deg,var(--coastal),var(--wave));color:#fff;font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 44px;transform:rotate(35deg);}
.price-type{font-size:.75rem;font-weight:700;color:var(--wave);letter-spacing:.09em;text-transform:uppercase;margin-bottom:6px;}
.price-card h3{font-family:var(--font-display);font-weight:700;font-size:1.1rem;color:var(--white);margin-bottom:18px;}
.price-amount{font-family:var(--font-display);font-weight:800;font-size:2.2rem;color:var(--foam);line-height:1;}
.price-amount small{font-size:1rem;font-weight:400;color:var(--gray);}
.price-note{font-size:.8rem;color:var(--gray);margin:4px 0 20px;}
.price-divider{border:none;border-top:1px solid var(--border);margin-bottom:20px;}
.price-features{list-style:none;display:flex;flex-direction:column;gap:10px;flex:1;margin-bottom:28px;}
.price-features li{display:flex;align-items:center;gap:10px;font-size:.875rem;color:var(--mist);}
.price-features svg{color:#22c55e;flex-shrink:0;}
.btn-book{display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,.06);color:var(--white);border:1px solid var(--border);text-decoration:none;font-weight:700;font-size:.9rem;padding:12px 18px;border-radius:11px;transition:all .2s;}
.btn-book:hover{background:rgba(42,127,186,.15);border-color:rgba(58,159,212,.4);transform:translateY(-2px);}
.btn-book.filled{background:linear-gradient(135deg,var(--coastal),var(--wave));border:none;box-shadow:0 4px 16px rgba(42,127,186,.4);}
.btn-book.filled:hover{box-shadow:0 8px 28px rgba(42,127,186,.55);}

/* WHY US */
#why{background:var(--midnight);}
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:32px;}
.why-num{font-family:var(--font-display);font-size:3rem;font-weight:800;color:rgba(58,159,212,.12);line-height:1;margin-bottom:12px;}
.why-card h3{font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--white);margin-bottom:8px;}
.why-card p{font-size:.875rem;color:var(--gray);line-height:1.65;}

/* HOW */
#how{background:var(--navy);}
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;}
.step-num{font-size:.75rem;font-weight:700;color:var(--wave);letter-spacing:.1em;text-transform:uppercase;margin-bottom:12px;}
.step-icon{width:48px;height:48px;border-radius:14px;background:rgba(42,127,186,.12);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--wave);margin-bottom:14px;}
.step h3{font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--white);margin-bottom:8px;}
.step p{font-size:.875rem;color:var(--gray);line-height:1.65;}

/* COVERAGE */
#coverage{background:var(--midnight);}
.coverage-areas{display:flex;flex-wrap:wrap;gap:10px;}
.area-tag{display:inline-flex;align-items:center;gap:6px;background:var(--card);border:1px solid var(--border);border-radius:50px;padding:8px 16px;font-size:.875rem;color:var(--white);transition:all .2s;cursor:default;backdrop-filter:blur(6px);}
.area-tag:hover{background:rgba(42,127,186,.18);border-color:rgba(58,159,212,.4);color:var(--foam);transform:scale(1.05);}
.area-tag svg{color:var(--wave);}

/* TESTIMONIALS */
#testimonials{background:var(--navy);}
.testimonials-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;}
.testimonial-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:26px;backdrop-filter:blur(8px);transition:transform .25s,box-shadow .25s;}
.testimonial-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-hover);}
.stars{color:#fbbf24;font-size:1rem;letter-spacing:2px;margin-bottom:14px;}
.testimonial-card blockquote{font-size:.93rem;color:var(--mist);line-height:1.7;margin-bottom:20px;font-style:italic;}
.reviewer{display:flex;align-items:center;gap:12px;}
.reviewer-avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--coastal),var(--wave));display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.85rem;color:#fff;flex-shrink:0;}
.reviewer strong{display:block;font-size:.875rem;color:var(--white);}
.reviewer span{font-size:.78rem;color:var(--gray);}

/* CONTACT */
#contact{background:var(--midnight);}
.contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:40px;align-items:start;}
@media(max-width:860px){.contact-grid{grid-template-columns:1fr;}}
.contact-channel{display:flex;align-items:center;gap:16px;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 20px;margin-bottom:14px;text-decoration:none;backdrop-filter:blur(8px);transition:all .2s;}
.contact-channel:hover{transform:translateX(6px);box-shadow:var(--shadow-hover);border-color:rgba(58,159,212,.3);}
.cc-icon{width:46px;height:46px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#fff;}
.cc-text strong{display:block;font-weight:700;font-size:.9rem;color:var(--white);}
.cc-text span{font-size:.82rem;color:var(--gray);}
.cc-arrow{margin-left:auto;color:var(--gray);}
.hours-box{background:rgba(42,127,186,.08);border:1px solid var(--border);border-radius:16px;padding:20px;margin-top:8px;}
.hours-box strong{display:block;color:var(--foam);margin-bottom:6px;font-size:.9rem;}
.hours-box p{font-size:.85rem;color:var(--gray);line-height:1.8;}
.hours-box .em{color:var(--wave);font-weight:600;}

/* FORM */
.booking-form-wrap{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:36px 32px;backdrop-filter:blur(8px);}
.booking-form-wrap h3{font-family:var(--font-display);font-weight:700;font-size:1.25rem;color:var(--white);margin-bottom:24px;}
.form-group{margin-bottom:16px;}
.form-group label{display:block;font-size:.82rem;font-weight:600;color:var(--mist);margin-bottom:6px;}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:12px 16px;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;font-size:.95rem;color:var(--white);font-family:inherit;outline:none;transition:border-color .2s;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--wave);}
.form-group select option{background:var(--navy);color:var(--white);}
.form-group textarea{resize:vertical;}
.form-submit{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;background:linear-gradient(135deg,var(--coastal),var(--wave));color:#fff;border:none;font-weight:700;font-size:1rem;padding:14px;border-radius:12px;cursor:pointer;font-family:inherit;box-shadow:0 4px 20px rgba(42,127,186,.4);transition:transform .2s,box-shadow .2s;}
.form-submit:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(42,127,186,.55);}
.form-note{font-size:.78rem;color:var(--gray);text-align:center;margin-top:10px;}
.form-success{text-align:center;padding:40px 0;display:none;}
.form-success.show{display:block;}
.form-success-icon{width:64px;height:64px;border-radius:50%;background:rgba(34,197,94,.12);margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:2rem;animation:popIn .5s cubic-bezier(.34,1.56,.64,1);}
@keyframes popIn{0%{transform:scale(0);}60%{transform:scale(1.2);}100%{transform:scale(1);}}
.form-success strong{display:block;font-weight:700;font-size:1.15rem;color:var(--white);margin-bottom:8px;}
.form-success p{color:var(--gray);font-size:.9rem;line-height:1.6;}
.form-success button{margin-top:20px;background:none;border:1px solid var(--border);border-radius:8px;padding:8px 18px;cursor:pointer;color:var(--gray);font-family:inherit;}

/* FOOTER */
footer{background:#060e1a;padding:56px clamp(20px,5vw,80px) 32px;border-top:1px solid var(--border);}
.footer-inner{max-width:1100px;margin:0 auto;}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr;gap:48px;margin-bottom:48px;}
@media(max-width:768px){.footer-top{grid-template-columns:1fr;}}
.footer-brand p{font-size:.875rem;color:var(--gray);line-height:1.75;max-width:280px;margin-top:14px;}
.footer-social{display:flex;gap:10px;margin-top:20px;}
.fs-link{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;text-decoration:none;transition:transform .2s;}
.fs-link:hover{transform:translateY(-3px) scale(1.1);}
.footer-heading{font-family:var(--font-display);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:.8rem;color:rgba(255,255,255,.3);margin-bottom:16px;}
.footer-col a{display:block;color:var(--gray);text-decoration:none;font-size:.875rem;margin-bottom:10px;transition:color .2s;}
.footer-col a:hover{color:var(--foam);}
.fc-label{font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.25);display:block;}
.footer-bottom{border-top:1px solid var(--border);padding-top:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.footer-bottom p{font-size:.8rem;color:var(--gray);}
.footer-cta{background:linear-gradient(135deg,var(--coastal),var(--wave));color:#fff;text-decoration:none;padding:9px 20px;border-radius:9px;font-size:.875rem;font-weight:700;transition:transform .2s;}
.footer-cta:hover{transform:scale(1.05);}

/* FLOATING CONTACT */
#floating-contact{position:fixed;bottom:28px;right:28px;z-index:999;display:flex;flex-direction:column;align-items:flex-end;gap:10px;}
.fc-option{display:flex;align-items:center;gap:10px;background:rgba(13,31,60,.98);border:1px solid var(--border);border-radius:50px;padding:10px 16px 10px 10px;text-decoration:none;box-shadow:0 8px 32px rgba(0,0,0,.4);opacity:0;transform:translateY(20px) scale(.8);pointer-events:none;transition:opacity .25s cubic-bezier(.22,1,.36,1),transform .25s cubic-bezier(.22,1,.36,1),box-shadow .2s;backdrop-filter:blur(12px);}
#floating-contact.open .fc-option{opacity:1;transform:translateY(0) scale(1);pointer-events:auto;}
#floating-contact.open .fc-option:nth-child(1){transition-delay:.18s;}
#floating-contact.open .fc-option:nth-child(2){transition-delay:.12s;}
#floating-contact.open .fc-option:nth-child(3){transition-delay:.06s;}
#floating-contact.open .fc-option:nth-child(4){transition-delay:0s;}
.fc-option:hover{transform:scale(1.06) translateX(-4px)!important;box-shadow:0 12px 40px rgba(0,0,0,.5);}
.fc-opt-icon{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;}
.fc-opt-label{font-weight:600;font-size:.875rem;color:var(--white);white-space:nowrap;}
.fc-toggle{width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,var(--coastal),var(--wave));color:#fff;border:none;cursor:pointer;box-shadow:0 6px 28px rgba(42,127,186,.5);display:flex;align-items:center;justify-content:center;transition:transform .3s,box-shadow .3s;font-size:1.5rem;}
.fc-toggle:hover{transform:scale(1.08);box-shadow:0 10px 36px rgba(42,127,186,.65);}
.fc-toggle.open{transform:rotate(45deg);}

/* SCROLL TOP */
#scroll-top{position:fixed;bottom:28px;left:28px;z-index:999;width:44px;height:44px;border-radius:50%;background:var(--navy-light);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--wave);font-size:1.2rem;opacity:0;transform:translateY(20px);pointer-events:none;transition:all .3s;box-shadow:var(--shadow);}
#scroll-top.show{opacity:1;transform:translateY(0);pointer-events:auto;}
#scroll-top:hover{transform:translateY(-3px) scale(1.1);background:rgba(42,127,186,.2);}

/* WA pulse */
@keyframes wapulse{0%,100%{box-shadow:0 6px 28px rgba(37,211,102,.5);}50%{box-shadow:0 6px 36px rgba(37,211,102,.8),0 0 0 8px rgba(37,211,102,.1);}}
</style>
</head>
<body>

