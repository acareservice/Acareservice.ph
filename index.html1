<button id="scroll-top" aria-label="Scroll to top">↑</button>

<script>
// NAVBAR
const navbar=document.getElementById('navbar');
window.addEventListener('scroll',()=>{
  navbar.classList.toggle('scrolled',window.scrollY>30);
  document.getElementById('scroll-top').classList.toggle('show',window.scrollY>400);
});

// MOBILE MENU
document.getElementById('hamburger').addEventListener('click',()=>document.getElementById('mobile-menu').classList.toggle('open'));
document.querySelectorAll('.mobile-menu a').forEach(a=>a.addEventListener('click',()=>document.getElementById('mobile-menu').classList.remove('open')));

// SCROLL REVEAL
const io=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.1,rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.reveal,.reveal-scale,.reveal-left,.reveal-right').forEach(el=>io.observe(el));

// PARTICLES
const pc=document.getElementById('particles');
const cols=['#3a9fd4','#2a7fba','#7ecef4'];
for(let i=0;i<14;i++){const p=document.createElement('div');p.className='particle';const s=4+(i%5)*3;p.style.cssText=`width:${s}px;height:${s}px;left:${(i*7.3)%92}%;top:${(i*11)%85}%;background:${cols[i%3]};animation-duration:${4+i*.6}s;animation-delay:${i*.25}s;`;pc.appendChild(p);}

// COVERAGE
const areas=["Pasig City","Makati","Taguig (BGC)","Mandaluyong","San Juan","Quezon City","Marikina","Cainta / Taytay","Antipolo","Parañaque","Las Piñas","Valenzuela","Caloocan","Manila City","Muntinlupa","Pateros"];
const ca=document.getElementById('coverage-areas');
areas.forEach((a,i)=>{const s=document.createElement('span');s.className='area-tag reveal-scale';s.style.setProperty('--i',i);s.innerHTML=`<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>${a}`;ca.appendChild(s);io.observe(s);});

// GALLERY LIGHTBOX
const gd=[
  {url:"https://images.pexels.com/photos/4108715/pexels-photo-4108715.jpeg?auto=compress&cs=tinysrgb&w=1200",label:"Split Type Cleaning",sub:"Residential — homes & condos"},
  {url:"https://images.pexels.com/photos/4108714/pexels-photo-4108714.jpeg?auto=compress&cs=tinysrgb&w=1200",label:"Unit Inspection",sub:"All brands serviced"},
  {url:"https://images.pexels.com/photos/8005397/pexels-photo-8005397.jpeg?auto=compress&cs=tinysrgb&w=1200",label:"HVAC Maintenance",sub:"Commercial office units"},
  {url:"https://images.pexels.com/photos/8005398/pexels-photo-8005398.jpeg?auto=compress&cs=tinysrgb&w=1200",label:"Repair & Tune-up",sub:"Same-day diagnosis & fix"},
  {url:"https://images.pexels.com/photos/8005384/pexels-photo-8005384.jpeg?auto=compress&cs=tinysrgb&w=1200",label:"Filter & Coil Washing",sub:"Deep clean — all brands"},
  {url:"https://images.pexels.com/photos/8005392/pexels-photo-8005392.jpeg?auto=compress&cs=tinysrgb&w=1200",label:"Preventive Maintenance",sub:"Keep your unit running right"},
];
function openLightbox(i){const d=gd[i];document.getElementById('lightbox-img').src=d.url;document.getElementById('lightbox-title').textContent=d.label;document.getElementById('lightbox-sub').textContent=d.sub;document.getElementById('lightbox').classList.add('open');document.body.style.overflow='hidden';}
function closeLightbox(e){document.getElementById('lightbox').classList.remove('open');document.body.style.overflow='';}

// FLOAT TOGGLE
const fc=document.getElementById('floating-contact');
const ft=document.getElementById('fc-toggle');
ft.addEventListener('click',()=>{fc.classList.toggle('open');ft.classList.toggle('open');});

// SCROLL TOP
document.getElementById('scroll-top').addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));

// BOOKING FORM
document.getElementById('booking-form').addEventListener('submit',function(e){
  e.preventDefault();
  const n=document.getElementById('f-name').value;
  const p=document.getElementById('f-phone').value;
  const t=document.getElementById('f-actype').value;
  const a=document.getElementById('f-area').value;
  const m=document.getElementById('f-message').value;
  const btn=document.getElementById('form-submit-btn');
  btn.textContent='Sending...';btn.disabled=true;
  const msg=`Hi ACare! I'd like to book a service.%0A%0AName: ${encodeURIComponent(n)}%0APhone: ${encodeURIComponent(p)}%0AAircon Type: ${encodeURIComponent(t)}%0AArea: ${encodeURIComponent(a)}%0AMessage: ${encodeURIComponent(m)}`;
  setTimeout(()=>{window.open(`https://wa.me/639938623225?text=${msg}`,'_blank');document.getElementById('booking-form').style.display='none';document.getElementById('form-success').classList.add('show');btn.innerHTML='<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.117 1.52 5.847L.057 23.982a.5.5 0 0 0 .614.614l6.135-1.463A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 0 1-5.034-1.386l-.36-.214-3.737.891.907-3.624-.234-.373A9.818 9.818 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg> Send via WhatsApp';btn.disabled=false;},700);
});
function resetForm(){document.getElementById('booking-form').reset();document.getElementById('booking-form').style.display='block';document.getElementById('form-success').classList.remove('show');}
</script>
</body>
</html>
